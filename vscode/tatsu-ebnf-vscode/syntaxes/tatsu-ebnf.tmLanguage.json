{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TatSu EBNF",
  "scopeName": "source.tatsu-ebnf",
  "patterns": [
    { "include": "#comment" },
    { "include": "#directive" },
    { "include": "#rule" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.tatsu-ebnf",
      "match": "#.*$"
    },
    "directive": {
      "match": "(@@)(\\w+)\\s*(::)\\s*(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.directive.tatsu-ebnf" },
        "2": { "name": "keyword.control.directive.tatsu-ebnf" },
        "3": { "name": "punctuation.separator.tatsu-ebnf" },
        "4": { "name": "string.unquoted.directive-value.tatsu-ebnf" }
      }
    },
    "rule": {
      "begin": "^(\\w+)\\s*(=)",
      "end": "(;)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.rule.tatsu-ebnf" },
        "2": { "name": "keyword.operator.assignment.tatsu-ebnf" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.terminator.rule.tatsu-ebnf" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#rule-body" }
      ]
    },
    "rule-body": {
      "patterns": [
        { "include": "#named-capture" },
        { "include": "#single-string" },
        { "include": "#double-string" },
        { "include": "#regex" },
        { "include": "#operators" },
        { "include": "#brackets" },
        { "include": "#rule-reference" }
      ]
    },
    "named-capture": {
      "match": "(\\w+)(\\+?:)",
      "captures": {
        "1": { "name": "variable.parameter.capture.tatsu-ebnf" },
        "2": { "name": "keyword.operator.capture.tatsu-ebnf" }
      }
    },
    "single-string": {
      "name": "string.quoted.single.tatsu-ebnf",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.tatsu-ebnf",
          "match": "''"
        }
      ]
    },
    "double-string": {
      "name": "string.quoted.double.tatsu-ebnf",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.tatsu-ebnf",
          "match": "\\\\\""
        }
      ]
    },
    "regex": {
      "name": "string.regexp.tatsu-ebnf",
      "begin": "/",
      "end": "/",
      "patterns": [
        {
          "name": "constant.character.escape.regex.tatsu-ebnf",
          "match": "\\\\/"
        },
        {
          "name": "keyword.operator.quantifier.regex.tatsu-ebnf",
          "match": "[*+?]"
        },
        {
          "name": "keyword.operator.or.regex.tatsu-ebnf",
          "match": "\\|"
        },
        {
          "name": "constant.other.character-class.regex.tatsu-ebnf",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "constant.character.escape.tatsu-ebnf",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "keyword.control.anchor.regex.tatsu-ebnf",
          "match": "[\\^$]"
        },
        {
          "name": "meta.group.regex.tatsu-ebnf",
          "begin": "\\(",
          "end": "\\)"
        },
        {
          "name": "constant.character.escape.tatsu-ebnf",
          "match": "\\\\."
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.alternation.tatsu-ebnf",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.end-of-input.tatsu-ebnf",
          "match": "\\$"
        },
        {
          "name": "keyword.operator.current-position.tatsu-ebnf",
          "match": "\\*"
        },
        {
          "name": "keyword.operator.separator.tatsu-ebnf",
          "match": ","
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "punctuation.section.group.begin.tatsu-ebnf",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.tatsu-ebnf",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.optional.begin.tatsu-ebnf",
          "match": "\\["
        },
        {
          "name": "punctuation.section.optional.end.tatsu-ebnf",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.repetition.begin.tatsu-ebnf",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.repetition.end.tatsu-ebnf",
          "match": "\\}"
        }
      ]
    },
    "rule-reference": {
      "name": "variable.other.rule-reference.tatsu-ebnf",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
