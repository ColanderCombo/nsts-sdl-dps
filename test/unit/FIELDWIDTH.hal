 FIELDWIDTH: PROGRAM;
    DECLARE N1 INTEGER INITIAL(1234), N2 INTEGER DOUBLE INITIAL(567);
    DECLARE X0 SCALAR INITIAL(0.0), X1 SCALAR INITIAL(1.0);
    DECLARE SCALAR DOUBLE, X2 INITIAL(0.0), X3 INITIAL(2.0);
    DECLARE C CHARACTER(200);
    WRITE(6) '1234567890123456789012345678901234567890';
    WRITE(6) N1;
    WRITE(6) N2;
    WRITE(6) X0;
    WRITE(6) X1;
    WRITE(6) X2;
    WRITE(6) X3;
    WRITE(6) 'A string',N1, N2, X0, X1, X2, X3;
    WRITE(6) 'A string' || N1 || N2 || X0 || X1 || X2 || X3;
    C = N1;
    WRITE(6) C;
    C = N2;
    WRITE(6) C;
    C = X0;
    WRITE(6) C;
    C = X1;
    WRITE(6) C;
    C = X2;
    WRITE(6) C;
    C = X3;
    WRITE(6) C;
    WRITE(6) '1234567890123456789012345678901234567890';
    WRITE(6) '';
Y %SVCI(0);
 CLOSE FIELDWIDTH;
