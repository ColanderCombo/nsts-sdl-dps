#!/bin/bash
# LNK101 wrapper script - auto-generated by CMake
# Uses the Python venv at: @SDL_VENV_DIR@
#

LIB_ARGS=()
USER_NO_DEFAULTS=0
for arg in "$@"; do
    if [ "$arg" = "--no-default-libs" ]; then
        USER_NO_DEFAULTS=1
        break
    fi
done
if [ $USER_NO_DEFAULTS -eq 0 ]; then
    # lnk101 tries to automatically add add RUN and ZCON to the search path,
    # but this won't work if we're not running with the right python venv.
    # Instead, cmake bakes in the full searchpaths here.  if --no-default-libs
    # is on the cmdline we'll skip this (just like on the python side):
    #
    [ -d "@WRAPPER_LIBDIR@/runtime/RUN" ]  && LIB_ARGS+=(-L "@WRAPPER_LIBDIR@/runtime/RUN")
    [ -d "@WRAPPER_LIBDIR@/runtime/ZCON" ] && LIB_ARGS+=(-L "@WRAPPER_LIBDIR@/runtime/ZCON")
fi

exec "@SDL_VENV_PYTHON@" -m lnk101 --no-default-libs "${LIB_ARGS[@]}" "$@"
