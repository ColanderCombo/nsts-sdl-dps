#!/bin/bash
# GPC unified simulator CLI wrapper — auto-generated by CMake
#
# Subcommands:
#   gpc run <fcm>       — batch execution
#   gpc debug <fcm>     — interactive REPL debugger
#   gpc dump <fcm>      — FCM dump report
#   gpc disasm <fcm>    — disassembly listing
#
SIM_DIR="@SIM_DIR@"
GPC_JS="${SIM_DIR}/dist/gpc.js"

exec node "${GPC_JS}" "$@"
